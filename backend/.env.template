# ═════════════════════════════════════════════════════════════════════════════
# .env — TalentLens AI Environment Configuration
# ═════════════════════════════════════════════════════════════════════════════
# Copy this to .env and fill in your values
# DO NOT commit .env to git — it contains secrets!

# ── Environment Type ──────────────────────────────────────────────────────────
# development | production
NODE_ENV=development

# ── Server Configuration ──────────────────────────────────────────────────────
PORT=10000

# ── Database (Supabase PostgreSQL — REQUIRED) ─────────────────────────────────
# Format: postgresql://user:password@host:port/database
# Get from: Supabase Dashboard > Settings > Database > Connection String (URI)
# ⚠️ Important: Use port 5432 (Session mode), not 6543 (Transaction mode)
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@db.bibqskupbovfewijtila.supabase.co:5432/postgres

# ── JWT Authentication ────────────────────────────────────────────────────────
# Secret key for JWT token signing (min 32 characters, use random string)
# Generate: python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET=8f3c7a9b2d5e1f4a6c8e0b3d5f7a9c1e2d4f6a8c0e2d4f6a8c0e2d4f6a8c1e
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ── AI Provider Configuration (Groq) ──────────────────────────────────────────
# Get API key from: https://console.groq.com/
AI_PROVIDER=groq
GROQ_API_KEY=gsk_YOUR_API_KEY_HERE
GROQ_API_URL=https://api.groq.com/openai/v1/chat/completions
GROQ_MODEL=llama3-8b-8192

# Available models: llama3-8b-8192, llama3-70b-8192, mixtral-8x7b-32768, etc.

# ── CORS Configuration ────────────────────────────────────────────────────────
# Frontend URL for CORS allowlist
# Local dev: http://localhost:5173
# Production: https://talentlens-ai.onrender.com
FRONTEND_URL=http://localhost:5173

# Allow requests from localhost (true for dev, false for production)
ALLOW_LOCALHOST_CORS=true

# Additional origins (comma-separated)
CORS_ORIGINS=

# ── Email (SMTP) Configuration ────────────────────────────────────────────────
# For Gmail: Use "App Passwords", not your regular email password
# Set up: https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-specific-password
SMTP_FROM=noreply@company.com

# ── Admin Seed Account ────────────────────────────────────────────────────────
# Created on first startup if it doesn't exist
# Change these credentials immediately in production!
ADMIN_EMAIL=admin@company.com
ADMIN_NAME=Admin
ADMIN_PASSWORD=Admin@123

# ── File Upload Configuration ─────────────────────────────────────────────────
UPLOAD_DIR=uploads

# ── Application Mode ─────────────────────────────────────────────────────────
# Set to 'true' if running on Render
RENDER=false
